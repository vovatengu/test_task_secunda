# Шаблон окружения. Скопируйте:
#   cp .env.example .env.dev    — для docker-compose.dev.yml
#   cp .env.example .env.test   — для docker-compose.test.yml (поменяйте ENVIRONMENT=testing, DB_NAME=payments_test)
# Для локального запуска без Docker: cp .env.example backend/.env  (поменяйте DB_HOST=localhost, RABBITMQ_HOST=localhost)

# ────────────── ENVIRONMENT ──────────────
ENVIRONMENT=development
PROJECT_NAME=payment-processing
LOG_LEVEL=INFO

# ────────────── API ──────────────
API_KEY=dev-api-key

# ────────────── DATABASE ──────────────
# DB_HOST=db        — Docker (сервис в compose)
# DB_HOST=localhost — локальный запуск без Docker
DB_NAME=payments
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=db
DB_PORT=5432

# DATABASE_URI собирается автоматически из компонентов выше.
# Задайте явно только если нужно переопределить:
# DATABASE_URI=postgresql+asyncpg://postgres:postgres@db:5432/payments

# ────────────── RABBITMQ ──────────────
# RABBITMQ_HOST=rabbitmq  — Docker (сервис в compose)
# RABBITMQ_HOST=localhost — локальный запуск без Docker
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672

# RABBITMQ_URL собирается автоматически из компонентов выше.
# Задайте явно только если нужно переопределить:
# RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/

# ────────────── ОПЦИОНАЛЬНО ──────────────
# GATEWAY_DELAY_MIN_SECONDS=2.0
# GATEWAY_DELAY_MAX_SECONDS=5.0
# GATEWAY_SUCCESS_PROBABILITY=0.9
# WEBHOOK_TIMEOUT_SECONDS=30.0
# OUTBOX_POLL_INTERVAL_SECONDS=1.0
